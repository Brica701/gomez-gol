#!/usr/bin/env node

var app = require('../app');
var debug = require('debug')('gomez-gol:server');
var http = require('http');
const { Server } = require("socket.io"); // 1. Importar Socket.io

var port = normalizePort(process.env.PORT || '3000');
app.set('port', port);

/**
 * Create HTTP server.
 */
var server = http.createServer(app);

/**
 * 2. Inicializar Socket.io y vincularlo al servidor
 */
const io = new Server(server, {
  cors: {
    origin: "*",
    methods: ["GET", "POST"]
  }
});

// 3. Inyectar io en la configuración de la app
app.setSocketIo(io);

io.on('connection', (socket) => {
  console.log('✅ Nuevo trabajador conectado al panel en tiempo real');
});

/**
 * Listen on provided port.
 */
server.listen(port);
server.on('error', onError);
server.on('listening', onListening);

function normalizePort(val) {
  var port = parseInt(val, 10);
  if (isNaN(port)) return val;
  if (port >= 0) return port;
  return false;
}

function onError(error) {
  if (error.syscall !== 'listen') throw error;
  var bind = typeof port === 'string' ? 'Pipe ' + port : 'Port ' + port;
  switch (error.code) {
    case 'EACCES':
      console.error(bind + ' requires elevated privileges');
      process.exit(1);
      break;
    case 'EADDRINUSE':
      console.error(bind + ' is already in use');
      process.exit(1);
      break;
    default:
      throw error;
  }
}

function onListening() {
  var addr = server.address();
  var bind = typeof addr === 'string' ? 'pipe ' + addr : 'port ' + addr.port;
  debug('Listening on ' + bind);
  console.log('🚀 Gomez-Gol operativo en ' + bind);
}