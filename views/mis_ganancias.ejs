<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Mis Ganancias | Gomez-Gol Pro 2026</title>
    <link rel="icon" href="data:,">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root {
            --primary-color: #28a745;
            --glass-bg: rgba(255, 255, 255, 0.08);
            --glass-border: rgba(255, 255, 255, 0.15);
            --streak-gold: #ffc107;
        }

        body {
            background: linear-gradient(rgba(0, 0, 0, 0.85), rgba(0, 0, 0, 0.85)),
            url('https://images.unsplash.com/photo-1574629810360-7efbbe195018?q=80&w=2000&auto=format&fit=crop');
            background-size: cover; background-position: center; background-attachment: fixed;
            min-height: 100vh; color: #ffffff !important;
            font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
            display: flex;
            flex-direction: column;
        }

        h4, h5, h6, span, label, div, td, th, a { color: #ffffff !important; }

        .navbar {
            background: rgba(0, 0, 0, 0.8) !important;
            backdrop-filter: blur(15px);
            border-bottom: 2px solid var(--primary-color);
        }

        .glass-card {
            background: var(--glass-bg);
            backdrop-filter: blur(20px);
            border: 1px solid var(--glass-border);
            border-radius: 20px;
            transition: all 0.4s ease;
        }

        .summary-val {
            font-weight: 800;
            letter-spacing: -1px;
            text-shadow: 0 2px 4px rgba(0,0,0,0.5);
        }

        .table {
            color: white !important;
            border-color: rgba(255,255,255,0.1);
        }

        .table thead th {
            background: rgba(0,0,0,0.2);
            border-bottom: 2px solid var(--primary-color);
            font-size: 0.7rem;
            letter-spacing: 1px;
        }

        .badge-result {
            background: rgba(255,255,255,0.1);
            border: 1px solid rgba(255,255,255,0.2);
            font-weight: 800;
        }

        .text-success-custom { color: #2ecc71 !important; }
        .text-info-custom { color: #38bdf8 !important; }

        /* ESTILOS FOOTER MAXIMIZADOS */
        .footer-glass {
            background: rgba(0, 0, 0, 0.7);
            backdrop-filter: blur(15px);
            border-top: 1px solid var(--glass-border);
            padding: 3rem 0 2rem 0;
            margin-top: auto;
        }

        .logo-container {
            background: rgba(255, 255, 255, 0.95);
            padding: 12px;
            border-radius: 15px;
            display: flex;
            align-items: center;
            justify-content: center;
            width: 180px;
            height: 85px;
            transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            box-shadow: 0 6px 20px rgba(0,0,0,0.4);
            overflow: hidden;
        }

        .logo-container:hover {
            transform: scale(1.05);
            background: #ffffff;
            box-shadow: 0 10px 30px rgba(40, 167, 69, 0.5);
        }

        .footer-logo {
            width: 100%;
            height: 100%;
            object-fit: contain;
            transform: scale(1.1);
        }

        @media (max-width: 576px) {
            .logo-container { width: 140px; height: 70px; }
        }
    </style>
</head>
<body>

<nav class="navbar navbar-dark sticky-top shadow">
    <div class="container d-flex justify-content-between align-items-center">
        <a class="navbar-brand fw-bold" href="/"><i class="fas fa-arrow-left me-2"></i> GOMEZ<span class="text-info">-GOL</span></a>
        <span class="small fw-bold text-uppercase opacity-75">Historial de <span class="text-info"><%= usuario %></span></span>
    </div>
</nav>

<div class="container mt-4 mb-5">
    <!-- Resumen de Ganancias -->
    <div class="row g-3 mb-4 text-center">
        <div class="col-4">
            <div class="glass-card p-3 border-info border-opacity-25">
                <div class="small opacity-75 text-uppercase fw-bold" style="font-size: 0.6rem;">Invertido</div>
                <div class="h3 m-0 text-info-custom summary-val"><%= resumen.total_apostado || 0 %></div>
                <small class="opacity-50 fw-bold">GmC</small>
            </div>
        </div>
        <div class="col-4">
            <div class="glass-card p-3 border-success border-opacity-25">
                <div class="small opacity-75 text-uppercase fw-bold" style="font-size: 0.6rem;">Ganado</div>
                <div class="h3 m-0 text-success-custom summary-val"><%= resumen.total_ganado || 0 %></div>
                <small class="opacity-50 fw-bold">GmC</small>
            </div>
        </div>
        <div class="col-4">
            <div class="glass-card p-3 border-warning border-opacity-25">
                <div class="small opacity-75 text-uppercase fw-bold" style="font-size: 0.6rem;">Puntos</div>
                <div class="h3 m-0 text-warning summary-val"><%= resumen.total_puntos || 0 %></div>
                <small class="opacity-50 fw-bold">PUNTOS</small>
            </div>
        </div>
    </div>

    <!-- Tabla de Historial -->
    <div class="glass-card p-4 shadow-lg">
        <h5 class="mb-4 text-uppercase fw-bold small text-success"><i class="fas fa-history me-2"></i> Partidos Finalizados</h5>
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead>
                <tr class="text-secondary small text-uppercase">
                    <th class="border-0 ps-3">Partido / Fecha</th>
                    <th class="border-0">Tu Apuesta</th>
                    <th class="border-0 text-center">Final</th>
                    <th class="border-0 text-center">Pts</th>
                    <th class="border-0 text-end pe-3">Premio</th>
                </tr>
                </thead>
                <tbody class="border-0">
                <% if(historial.length === 0) { %>
                    <tr><td colspan="5" class="text-center opacity-50 py-5">No hay partidos finalizados aún.</td></tr>
                <% } %>
                <% historial.forEach(ap => { %>
                    <tr style="border-bottom: 1px solid rgba(255,255,255,0.05);">
                        <td class="ps-3 py-3">
                            <div class="fw-bold small text-uppercase"><%= ap.equipo_a %> <span class="text-info">vs</span> <%= ap.equipo_b %></div>
                            <div class="opacity-50 fw-bold" style="font-size: 0.65rem;"><i class="far fa-calendar-alt me-1"></i> <%= ap.fecha %></div>
                        </td>
                        <td>
                            <span class="badge badge-result px-3 py-2 rounded-pill"><%= ap.goles_a %> - <%= ap.goles_b %></span>
                        </td>
                        <td class="text-center">
                            <span class="badge bg-success bg-opacity-25 text-success-custom border border-success border-opacity-50 px-3 py-2 rounded-pill fw-bold">
                                <%= ap.resultado_a %> - <%= ap.resultado_b %>
                            </span>
                        </td>
                        <td class="text-center">
                            <div class="fw-bold text-warning">+<%= ap.puntos_obtenidos %></div>
                        </td>
                        <td class="text-end pe-3">
                            <div class="fw-bold <%= ap.premio_monedas > 0 ? 'text-success-custom' : 'text-danger' %>">
                                <%= ap.premio_monedas > 0 ? '+' + ap.premio_monedas : '0' %> <small class="opacity-75">GmC</small>
                            </div>
                        </td>
                    </tr>
                <% }) %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<footer class="footer-glass">
    <div class="container">
        <div class="row align-items-center justify-content-center g-4">
            <div class="col-auto">
                <div class="logo-container">
                    <img src="/images/cuadrotek.png" alt="CuadroTek" class="footer-logo">
                </div>
            </div>
            <div class="col-auto">
                <div class="logo-container">
                    <img src="/images/gomez_moreno_logo (1)-nobg.svg" alt="Gomez Moreno" class="footer-logo">
                </div>
            </div>
            <div class="col-auto">
                <div class="logo-container">
                    <img src="/images/mercasat.png" alt="Mercasat" class="footer-logo">
                </div>
            </div>
        </div>
        <div class="row mt-5">
            <div class="col-12 text-center">
                <p class="small opacity-50 mb-0" style="font-size: 0.75rem; letter-spacing: 2px;">
                    © 2026 GOMEZ-GOL | DESARROLLADO POR ISAAC CRUZ
                </p>
            </div>
        </div>
    </div>
</footer>

</body>
</html>