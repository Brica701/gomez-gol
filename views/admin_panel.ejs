<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin - Gomez-Gol Control</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root {
            --bg-deep: #0f172a;
            --card-bg: #1e293b;
            --accent: #38bdf8;
            --success: #22c55e;
            --warning: #f59e0b;
            --danger: #ef4444;
        }

        body { background: var(--bg-deep); color: #ffffff !important; font-family: 'Inter', sans-serif; }
        h1, h2, h3, h4, h5, h6, p, span, label, td, th, strong, small, div { color: #ffffff !important; }

        .stat-card {
            background: var(--card-bg);
            border-left: 4px solid var(--accent);
            border-radius: 10px;
            padding: 1.5rem;
            transition: transform 0.2s;
        }

        .text-warning-bold { color: #fbbf24 !important; font-weight: bold; }
        .text-success-bold { color: #4ade80 !important; font-weight: bold; }
        .text-info-bold { color: #7dd3fc !important; font-weight: bold; }
        .text-muted-white { color: #cbd5e1 !important; opacity: 0.8; }

        .nav-tabs { border-bottom: 2px solid #334155; }
        .nav-tabs .nav-link {
            color: #ffffff !important; border: none; padding: 1rem 1.5rem;
            font-weight: 600; opacity: 0.6;
        }
        .nav-tabs .nav-link.active {
            background: transparent; color: var(--accent) !important;
            border-bottom: 3px solid var(--accent); opacity: 1;
        }

        .card-admin {
            background: var(--card-bg);
            border: 1px solid #334155;
            border-radius: 15px;
            overflow: hidden;
            box-shadow: 0 10px 30px rgba(0,0,0,0.5);
        }

        .table { color: #ffffff !important; }
        .table thead th { color: var(--accent) !important; background: rgba(255,255,255,0.05); border: none; }
        .table td { border-color: #334155 !important; background: transparent !important; color: #ffffff !important; }

        .input-dark {
            background: #0f172a !important;
            border: 1px solid #475569 !important;
            color: #ffffff !important;
            font-weight: bold;
        }
        .input-dark:focus { border-color: var(--accent) !important; box-shadow: 0 0 0 0.25rem rgba(56, 189, 248, 0.25); }
        .input-dark::placeholder { color: #64748b !important; font-weight: normal; font-size: 0.85rem; }

        .badge-status { padding: 8px 12px; border-radius: 6px; font-size: 0.75rem; font-weight: bold; }
        .btn-action { border-radius: 8px; font-weight: 600; }

        .status-pill {
            font-size: 0.7rem;
            padding: 2px 8px;
            border-radius: 20px;
            text-transform: uppercase;
        }
    </style>
</head>
<body class="p-3 p-md-4">

<div class="container-fluid">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-center mb-4 gap-3">
        <div>
            <h2 class="mb-0 fw-bold text-info-bold"><i class="fas fa-user-shield me-2"></i>Control Gómez Moreno</h2>
            <p class="text-muted-white mb-0">Gestión de Porras y Seguridad 2026</p>
        </div>
        <div class="d-flex gap-2">
            <form action="/admin/sincronizar-partidos" method="POST">
                <button type="submit" class="btn btn-outline-info btn-action"><i class="fas fa-sync-alt me-2"></i>Sincronizar API</button>
            </form>
            <a href="/" class="btn btn-primary btn-action">Ir al Juego <i class="fas fa-external-link-alt ms-1"></i></a>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-6 col-md-3">
            <div class="stat-card">
                <small class="text-muted-white d-block mb-1 text-uppercase">Usuarios</small>
                <h3 class="fw-bold mb-0"><%= usuarios.length %></h3>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="stat-card" style="border-color: var(--warning);">
                <small class="text-muted-white d-block mb-1 text-uppercase">Partidos Activos</small>
                <h3 class="fw-bold mb-0 text-warning-bold"><%= partidos.filter(p => p.estado !== 'finalizado').length %></h3>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="stat-card" style="border-color: var(--success);">
                <small class="text-muted-white d-block mb-1 text-uppercase">Total en Juego</small>
                <h3 class="fw-bold mb-0 text-success-bold">
                    <%= transacciones.filter(t => t.puntos_obtenidos === 0).reduce((acc, t) => acc + t.apostado, 0) %> <small style="font-size: 0.5em;">GmC</small>
                </h3>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="stat-card" style="border-color: #a855f7;">
                <small class="text-muted-white d-block mb-1 text-uppercase">Apuestas Totales</small>
                <h3 class="fw-bold mb-0" style="color: #d8b4fe !important;"><%= transacciones.length %></h3>
            </div>
        </div>
    </div>

    <ul class="nav nav-tabs mb-4" id="adminTabs" role="tablist">
        <li class="nav-item"><button class="nav-link active" data-bs-toggle="tab" data-bs-target="#tab-usuarios"><i class="fas fa-users me-2"></i>Usuarios y Seguridad</button></li>
        <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-partidos"><i class="fas fa-futbol me-2"></i>Partidos</button></li>
        <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-transacciones"><i class="fas fa-history me-2"></i>Historial</button></li>
    </ul>

    <div class="tab-content">
        <div class="tab-pane fade show active" id="tab-usuarios">
            <div class="card card-admin p-4 mb-4 border-0">
                <h5 class="mb-4 fw-bold text-info-bold"><i class="fas fa-user-plus me-2"></i>Nuevo Jugador</h5>
                <form action="/admin/usuarios/add" method="POST" class="row g-3">
                    <div class="col-md-4"><input type="text" name="nombre" class="form-control input-dark py-2" placeholder="Nombre" required></div>
                    <div class="col-md-3"><input type="password" name="password" class="form-control input-dark py-2" placeholder="Password Temporal" required></div>
                    <div class="col-md-3"><input type="number" name="creditos" class="form-control input-dark py-2" value="1000" placeholder="Créditos"></div>
                    <div class="col-md-2"><button type="submit" class="btn btn-info w-100 fw-bold py-2 text-white">Registrar</button></div>
                </form>
            </div>

            <div class="card card-admin border-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead>
                        <tr>
                            <th>Nombre</th>
                            <th>Créditos</th>
                            <th>Puntos</th>
                            <th>Nueva Password</th>
                            <th class="text-center">Acciones</th>
                        </tr>
                        </thead>
                        <tbody>
                        <% usuarios.forEach(u => { %>
                            <tr>
                                <form action="/admin/usuarios/edit" method="POST">
                                    <input type="hidden" name="nombre" value="<%= u.nombre %>">
                                    <td class="fw-bold fs-5 text-white">
                                        <%= u.nombre %>
                                        <% if(u.debe_cambiar_pass) { %>
                                            <span class="status-pill bg-warning text-dark d-block" style="width: fit-content;">Reset Pendiente</span>
                                        <% } %>
                                    </td>
                                    <td><input type="number" name="creditos" class="form-control input-dark form-control-sm w-75" value="<%= u.creditos %>"></td>
                                    <td><input type="number" name="puntos" class="form-control input-dark form-control-sm w-75" value="<%= u.puntos %>"></td>
                                    <td>
                                        <input type="password" name="nueva_password" class="form-control input-dark form-control-sm" placeholder="Escribir para resetear">
                                    </td>
                                    <td>
                                        <div class="d-flex justify-content-center gap-2">
                                            <button type="submit" class="btn btn-success btn-sm px-3 fw-bold"><i class="fas fa-save me-1"></i> Actualizar</button>
                                </form>
                                <form action="/admin/usuarios/delete" method="POST" onsubmit="return confirm('¿Eliminar a este usuario?')" style="display:inline;">
                                    <input type="hidden" name="nombre" value="<%= u.nombre %>">
                                    <button type="submit" class="btn btn-outline-danger btn-sm"><i class="fas fa-trash-alt"></i></button>
                                </form>
                </div>
                </td>
                </tr>
                <% }) %>
                </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="tab-pane fade" id="tab-partidos">
        <div class="card card-admin p-0 border-0">
            <% partidos.forEach(p => { %>
                <div class="p-4 border-bottom border-secondary <%= p.estado === 'finalizado' ? 'bg-dark bg-opacity-25' : '' %>">
                    <form action="/admin/finalizar-partido" method="POST" class="row align-items-center g-3">
                        <input type="hidden" name="id_partido" value="<%= p.id %>">
                        <div class="col-md-4">
                            <strong class="fs-5 d-block text-white"><%= p.equipo_a %> vs <%= p.equipo_b %></strong>
                            <small class="text-info-bold"><%= new Date(p.fecha_partido).toLocaleString() %></small>
                        </div>
                        <% if(p.estado !== 'finalizado') { %>
                            <div class="col-md-2"><input type="number" name="resultado_a" class="form-control input-dark text-center" placeholder="Goles A"></div>
                            <div class="col-md-2"><input type="number" name="resultado_b" class="form-control input-dark text-center" placeholder="Goles B"></div>
                            <div class="col-md-4 text-end">
                                <button type="submit" class="btn btn-warning w-100 fw-bold py-2 text-dark"><i class="fas fa-check-double me-2"></i>Finalizar y Repartir</button>
                            </div>
                        <% } else { %>
                            <div class="col-md-8 text-end">
                                <span class="badge-status bg-success text-white border border-white fs-6">FINALIZADO: <%= p.resultado_a %> - <%= p.resultado_b %></span>
                            </div>
                        <% } %>
                    </form>
                </div>
            <% }) %>
        </div>
    </div>

    <div class="tab-pane fade" id="tab-transacciones">
        <div class="card card-admin border-0">
            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead>
                    <tr>
                        <th>Usuario</th>
                        <th>Partido</th>
                        <th class="text-center">Porra</th>
                        <th class="text-center">Apostado</th>
                        <th>Premio</th>
                        <th>Estado</th>
                    </tr>
                    </thead>
                    <tbody>
                    <% transacciones.forEach(t => { %>
                        <tr>
                            <td class="fw-bold text-info-bold"><%= t.usuario %></td>
                            <td class="text-white"><%= t.equipo_a %> vs <%= t.equipo_b %></td>
                            <td class="text-center"><span class="badge bg-light text-dark px-3 py-2 fw-bold"><%= t.goles_a %> - <%= t.goles_b %></span></td>
                            <td class="text-center fw-bold text-warning-bold"><%= t.apostado %> GmC</td>
                            <td class="fw-bold text-success-bold"><%= t.puntos_obtenidos %> pts</td>
                            <td><span class="badge-status <%= t.puntos_obtenidos > 0 ? 'bg-success text-white' : 'bg-warning text-dark' %>"><%= t.puntos_obtenidos > 0 ? 'PAGADO' : 'PENDIENTE' %></span></td>
                        </tr>
                    <% }) %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
</div>

<script src="https://cdn.socket.io/4.7.5/socket.io.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script>
    const socket = io();
    socket.on('update_porra', () => location.reload());
</script>
</body>
</html>