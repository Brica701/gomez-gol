<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <title>Gomez-Gol Pro | 2026</title>
  <link rel="icon" href="data:,">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <style>
    :root {
      --primary-color: #28a745;
      --glass-bg: rgba(255, 255, 255, 0.08);
      --glass-border: rgba(255, 255, 255, 0.15);
      --streak-gold: #ffc107;
    }

    body {
      background: linear-gradient(rgba(0, 0, 0, 0.85), rgba(0, 0, 0, 0.85)),
      url('https://images.unsplash.com/photo-1574629810360-7efbbe195018?q=80&w=2000&auto=format&fit=crop');
      background-size: cover; background-position: center; background-attachment: fixed;
      min-height: 100vh; color: #ffffff !important;
      font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
      display: flex;
      flex-direction: column;
    }

    h4, h5, h6, span, label, div, td, th, a { color: #ffffff !important; }

    .navbar {
      background: rgba(0, 0, 0, 0.8) !important;
      backdrop-filter: blur(15px);
      border-bottom: 2px solid var(--primary-color);
    }

    .glass-card {
      background: var(--glass-bg);
      backdrop-filter: blur(20px);
      border: 1px solid var(--glass-border);
      border-radius: 20px;
      transition: all 0.4s ease;
    }

    /* FILTRO DE FECHAS */
    .date-filter-box {
      background: rgba(0,0,0,0.4);
      border-radius: 15px;
      padding: 10px;
      border: 1px solid var(--glass-border);
    }
    .date-input-custom {
      background: #fff !important;
      color: #000 !important;
      border-radius: 8px;
      font-weight: bold;
    }

    .escudo-team {
      width: 40px;
      height: 40px;
      object-fit: contain;
      margin-bottom: 5px;
      filter: drop-shadow(0 2px 4px rgba(0,0,0,0.5));
    }

    .partido-hidden { display: none !important; }

    .streak-badge {
      background: rgba(255, 193, 7, 0.15);
      border: 1px solid var(--streak-gold);
      color: var(--streak-gold) !important;
      font-size: 0.75rem;
      font-weight: 800;
    }

    .btn-ban { cursor: pointer; display: none; font-size: 0.7rem; vertical-align: middle; }
    .msg:hover .btn-ban { display: inline-block; }

    .partidos-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
      gap: 1rem;
    }

    .vs-circle {
      width: 32px; height: 32px; background: var(--primary-color);
      border-radius: 50%; display: flex; align-items: center; justify-content: center;
      font-weight: 900; margin: 0 auto; font-size: 0.65rem;
    }

    .form-control-mobile {
      background: rgba(255, 255, 255, 0.9) !important;
      border: 1px solid rgba(255, 255, 255, 0.2) !important;
      color: #000000 !important; border-radius: 10px; text-align: center;
      font-weight: bold;
    }
    .form-control-mobile::placeholder { color: #666; }

    .btn-bet { background: var(--primary-color); border: none; border-radius: 10px; font-weight: 800; }
    .btn-bet:disabled { background: #6c757d; opacity: 0.6; }

    #chat-container {
      position: fixed; bottom: 90px; right: 20px; width: 350px; height: 500px;
      z-index: 1050; display: none; flex-direction: column;
      border-radius: 20px; overflow: hidden;
    }
    #chat-messages { height: 390px; overflow-y: auto; scrollbar-width: thin; display: flex; flex-direction: column; }
    .msg { max-width: 85%; padding: 8px 12px; border-radius: 15px; font-size: 0.85rem; position: relative; margin-bottom: 8px; color: white !important; }
    .msg-others { align-self: flex-start; background: rgba(255,255,255,0.15); border-bottom-left-radius: 2px; }
    .msg-me { align-self: flex-end; background: var(--primary-color); border-bottom-right-radius: 2px; }
    .msg-user { font-size: 0.65rem; font-weight: bold; display: block; opacity: 0.8; color: #38bdf8 !important; }
    .btn-del { position: absolute; top: -5px; right: -5px; cursor: pointer; display: none; }
    .msg:hover .btn-del { display: block; }

    /* ESTILOS FOOTER MAXIMIZADOS */
    .footer-glass {
      background: rgba(0, 0, 0, 0.7);
      backdrop-filter: blur(15px);
      border-top: 1px solid var(--glass-border);
      padding: 3rem 0 2rem 0;
      margin-top: auto;
    }

    .logo-container {
      background: rgba(255, 255, 255, 0.95);
      padding: 12px;
      border-radius: 15px;
      display: flex;
      align-items: center;
      justify-content: center;
      width: 180px;
      height: 85px;
      transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
      box-shadow: 0 6px 20px rgba(0,0,0,0.4);
      overflow: hidden;
    }

    .logo-container:hover {
      transform: scale(1.05);
      background: #ffffff;
      box-shadow: 0 10px 30px rgba(40, 167, 69, 0.5);
    }

    .footer-logo {
      width: 100%;
      height: 100%;
      object-fit: contain;
      transform: scale(1.1);
    }

    @media (max-width: 576px) {
      #chat-container { width: 94%; right: 3%; bottom: 80px; height: 75vh; }
      .logo-container { width: 140px; height: 70px; }
    }
  </style>
</head>
<body>

<nav class="navbar navbar-dark sticky-top shadow">
  <div class="container d-flex justify-content-between align-items-center">
    <a class="navbar-brand fw-bold" href="#">GOMEZ<span class="text-info">-GOL</span></a>
    <div class="d-flex align-items-center gap-2">
      <a href="/reglas" class="btn btn-outline-warning rounded-pill px-3 btn-sm fw-bold">
        <i class="fas fa-book me-1"></i> Reglas
      </a>
      <button onclick="setChat(null, 'Chat General')" class="btn btn-outline-info rounded-pill px-3 btn-sm">
        <i class="fas fa-globe me-1"></i> General
      </button>
      <div class="streak-badge px-2 py-1 rounded-pill">
        <i class="fas fa-fire me-1"></i> x<span id="user-racha-top"><%= user.racha_ganador || 0 %></span>
      </div>
      <div class="badge-coins border border-success px-3 py-1 rounded-pill bg-dark bg-opacity-50">
        <i class="fas fa-coins text-warning me-1"></i> <span id="user-creditos-top"><%= user.creditos %></span>
      </div>
      <% if (user.rol === 'admin') { %>
        <a href="/admin" class="ms-1 text-white"><i class="fas fa-user-shield fs-5"></i></a>
      <% } %>
    </div>
  </div>
</nav>

<div class="container mt-3 mb-5">
  <div class="date-filter-box d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
    <h6 class="m-0 text-uppercase small fw-bold text-success"><i class="fas fa-calendar-day me-2"></i> Filtrar Partidos</h6>
    <div class="d-flex gap-2">
      <button class="btn btn-sm btn-outline-success" onclick="setQuickDate(0)">Hoy</button>
      <button class="btn btn-sm btn-outline-light" onclick="setQuickDate(1)">Mañana</button>
      <input type="date" id="main-date-picker" class="form-control form-control-sm date-input-custom" onchange="filterMatchesByDate(this.value)">
    </div>
  </div>

  <div class="row mb-4">
    <div class="col-12">
      <a href="/mis-ganancias" class="btn btn-success w-100 fw-bold shadow-sm py-2">
        <i class="fas fa-hand-holding-usd me-2"></i> VER MIS GANANCIAS Y PUNTOS TOTALES
      </a>
    </div>
  </div>

  <div class="row g-4">
    <div class="col-lg-9">
      <h5 class="mb-3 text-uppercase fw-bold text-success small"><i class="fas fa-check-circle me-2"></i> Mis Apuestas Realizadas</h5>
      <div id="mis-apuestas-container" class="partidos-grid mb-5">
        <%
        let apostados = partidos.filter(p => apuestas_usuario.find(a => a.id_partido === p.id));
        if(apostados.length === 0) {
        %>
          <div id="no-apuestas-msg" class="col-12 opacity-50 small ps-2">No tienes apuestas para este día.</div>
        <% } else {
        apostados.forEach(partido => {
          const yaAposto = apuestas_usuario.find(a => a.id_partido === partido.id);
          const fISO = new Date(partido.fecha_partido).toISOString().split('T')[0];
          // CORRECCIÓN HORARIA AQUÍ
          const horaEsp = new Date(partido.fecha_partido).toLocaleTimeString('es-ES', {hour: '2-digit', minute:'2-digit', hour12: false});
        %>
        <div class="card glass-card p-3 shadow-sm border-success partido-card-<%= partido.id %> match-item" data-date="<%= fISO %>">
          <div class="d-flex justify-content-between mb-2">
            <span class="small opacity-75"><i class="far fa-clock me-1"></i> <%= horaEsp %></span>
            <% if (partido.en_vivo) { %>
              <span class="badge bg-danger text-white blink" style="font-size: 0.6rem;">EN CURSO</span>
            <% } %>
            <button onclick="setChat('<%= partido.id %>', '<%= partido.equipo_a %> vs <%= partido.equipo_b %>')" class="btn btn-sm btn-info py-0 px-2 text-dark fw-bold" style="font-size: 0.65rem;">CHAT</button>
          </div>
          <div class="row align-items-center text-center my-2">
            <div class="col-5">
              <img src="https://crests.football-data.org/<%= partido.id_api_a %>.png" onerror="this.src='https://cdn-icons-png.flaticon.com/512/53/53283.png'" class="escudo-team"><br>
              <span class="fw-bold small text-uppercase"><%= partido.equipo_a %></span>
            </div>
            <div class="col-2 p-0"><div class="vs-circle">VS</div></div>
            <div class="col-5">
              <img src="https://crests.football-data.org/<%= partido.id_api_b %>.png" onerror="this.src='https://cdn-icons-png.flaticon.com/512/53/53283.png'" class="escudo-team"><br>
              <span class="fw-bold small text-uppercase"><%= partido.equipo_b %></span>
            </div>
          </div>
          <div class="text-center mb-2">
              <span class="badge bg-dark bg-opacity-50 border border-info border-opacity-25 rounded-pill px-3 py-1" style="font-size: 0.7rem;">
                <i class="fas fa-vault text-info me-1"></i> BOLSA: <span class="text-info fw-bold bolsa-partido-<%= partido.id %>"><%= partido.total_apostado || 0 %> GmC</span>
              </span>
          </div>
          <div class="text-center py-2 rounded-3 bg-white shadow-sm border border-success">
            <span class="text-dark small fw-bold text-uppercase">Tu Apuesta: <%= yaAposto.goles_a %> - <%= yaAposto.goles_b %></span>
            <div class="text-dark fw-bold small" style="font-size: 0.6rem;">(<%= yaAposto.apostado %> GmC)</div>
          </div>
        </div>
        <% })} %>
      </div>

      <h5 class="mb-3 text-uppercase fw-bold opacity-75 small"><i class="fas fa-futbol me-2"></i> Partidos Disponibles</h5>
      <div id="disponibles-container" class="partidos-grid mb-5">
        <%
        let pendientes = partidos.filter(p => !apuestas_usuario.find(a => a.id_partido === p.id));
        pendientes.forEach(partido => {
          const isBloqueado = partido.bloqueado === 1;
          const fISO = new Date(partido.fecha_partido).toISOString().split('T')[0];
          // CORRECCIÓN HORARIA AQUÍ
          const horaEsp = new Date(partido.fecha_partido).toLocaleTimeString('es-ES', {hour: '2-digit', minute:'2-digit', hour12: false});
        %>
        <div class="card glass-card p-3 shadow-sm partido-card-<%= partido.id %> match-item" data-date="<%= fISO %>" style="<%= isBloqueado ? 'opacity: 0.8;' : '' %>">
          <div class="d-flex justify-content-between mb-2">
            <span class="small opacity-75"><i class="far fa-clock me-1"></i> <%= horaEsp %></span>
            <% if (isBloqueado) { %>
              <span class="badge bg-secondary text-white" style="font-size: 0.6rem;">CERRADO</span>
            <% } %>
            <button onclick="setChat('<%= partido.id %>', '<%= partido.equipo_a %> vs <%= partido.equipo_b %>')" class="btn btn-sm btn-info py-0 px-2 text-dark fw-bold" style="font-size: 0.65rem;">CHAT</button>
          </div>
          <div class="row align-items-center text-center my-2">
            <div class="col-5">
              <img src="https://crests.football-data.org/<%= partido.id_api_a %>.png" onerror="this.src='https://cdn-icons-png.flaticon.com/512/53/53283.png'" class="escudo-team"><br>
              <span class="fw-bold small text-uppercase"><%= partido.equipo_a %></span>
            </div>
            <div class="col-2 p-0"><div class="vs-circle">VS</div></div>
            <div class="col-5">
              <img src="https://crests.football-data.org/<%= partido.id_api_b %>.png" onerror="this.src='https://cdn-icons-png.flaticon.com/512/53/53283.png'" class="escudo-team"><br>
              <span class="fw-bold small text-uppercase"><%= partido.equipo_b %></span>
            </div>
          </div>

          <div class="text-center mb-3">
              <span class="badge bg-dark bg-opacity-50 border border-info border-opacity-25 rounded-pill px-3 py-1" style="font-size: 0.7rem;">
                <i class="fas fa-vault text-info me-1"></i> BOLSA TOTAL: <span class="text-info fw-bold bolsa-partido-<%= partido.id %>"><%= partido.total_apostado || 0 %> GmC</span>
              </span>
          </div>

          <form class="mt-2 form-apuesta-ajax">
            <input type="hidden" name="id_partido" value="<%= partido.id %>">
            <div class="row g-1">
              <div class="col-3"><input type="number" name="goles_a" class="form-control-mobile w-100 py-1" placeholder="L" required <%= isBloqueado ? 'disabled' : '' %>></div>
              <div class="col-3"><input type="number" name="goles_b" class="form-control-mobile w-100 py-1" placeholder="V" required <%= isBloqueado ? 'disabled' : '' %>></div>
              <div class="col-4"><input type="number" name="apostado" class="form-control-mobile w-100 py-1 text-warning" placeholder="GmC" min="50" required <%= isBloqueado ? 'disabled' : '' %>></div>
              <div class="col-2">
                <button type="submit" class="btn btn-bet w-100 py-1" <%= isBloqueado ? 'disabled' : '' %>>
                  <i class="fas <%= isBloqueado ? 'fa-lock' : 'fa-check' %>"></i>
                </button>
              </div>
            </div>
          </form>
        </div>
        <% }) %>
      </div>
    </div>

    <div class="col-lg-3">
      <h5 class="mb-3 text-uppercase fw-bold opacity-75 small"><i class="fas fa-fire-alt text-warning me-2"></i> Mis Rachas Actuales</h5>
      <div class="card glass-card p-3 mb-4 border-warning border-opacity-25">
        <div class="d-flex justify-content-between align-items-center mb-2">
          <span class="small fw-bold">Aciertos Seguidos:</span>
          <span class="badge streak-gold text-dark bg-warning px-2" id="racha-ganador-panel"><%= user.racha_ganador || 0 %></span>
        </div>
        <div class="d-flex justify-content-between align-items-center mb-3">
          <span class="small fw-bold">Plenos Seguidos:</span>
          <span class="badge bg-info text-dark px-2" id="racha-exacta-panel"><%= user.racha_exacta || 0 %></span>
        </div>
      </div>

      <h5 class="mb-3 text-uppercase fw-bold opacity-75 small">🏆 Ranking</h5>
      <div class="card glass-card overflow-hidden border-0 mb-4">
        <table class="table table-dark table-sm mb-0">
          <tbody>
          <% ranking.slice(0, 10).forEach((u, i) => { %>
            <tr>
              <td class="ps-3 py-2 text-info fw-bold"><%= i + 1 %></td>
              <td class="text-uppercase small"><%= u.nombre %></td>
              <td class="text-end pe-3 fw-bold"><%= u.puntos %> <small class="opacity-50">pts</small></td>
            </tr>
          <% }) %>
          </tbody>
        </table>
      </div>
      <a href="/logout" class="btn btn-outline-danger btn-sm w-100 mb-3">CERRAR SESIÓN</a>
    </div>
  </div>
</div>

<footer class="footer-glass">
  <div class="container">
    <div class="row align-items-center justify-content-center g-4">
      <div class="col-auto">
        <div class="logo-container">
          <img src="/images/cuadrotek.png" alt="CuadroTek" class="footer-logo">
        </div>
      </div>
      <div class="col-auto">
        <div class="logo-container">
          <img src="/images/gomez_moreno_logo (1)-nobg.svg" alt="Gomez Moreno" class="footer-logo">
        </div>
      </div>
      <div class="col-auto">
        <div class="logo-container">
          <img src="/images/mercasat.png" alt="Mercasat" class="footer-logo">
        </div>
      </div>
    </div>
    <div class="row mt-5">
      <div class="col-12 text-center">
        <p class="small opacity-50 mb-0" style="font-size: 0.75rem; letter-spacing: 2px;">
          © 2026 GOMEZ-GOL | DESARROLLADO POR ISAAC CRUZ
        </p>
      </div>
    </div>
  </div>
</footer>

<div id="chat-container" class="glass-card shadow-lg flex-column">
  <div class="p-3 border-bottom border-white border-opacity-10 d-flex justify-content-between align-items-center bg-dark">
    <h6 class="m-0 fw-bold small"><i class="fas fa-comment text-info me-2"></i> <span id="chat-title">General</span></h6>
    <button class="btn-close btn-close-white" onclick="toggleChat()"></button>
  </div>
  <div id="chat-messages" class="flex-grow-1 p-3"></div>
  <div class="p-2 border-top border-white border-opacity-10 bg-dark">
    <div class="input-group input-group-sm">
      <input type="text" id="chat-input" class="form-control bg-transparent border-0 text-white" placeholder="Escribe un mensaje..." onkeypress="if(event.key==='Enter') enviarMensaje()">
      <button class="btn text-info border-0" onclick="enviarMensaje()"><i class="fas fa-paper-plane"></i></button>
    </div>
  </div>
</div>

<button onclick="toggleChat()" class="btn btn-success shadow-lg rounded-circle" style="position: fixed; bottom: 20px; right: 20px; width: 55px; height: 55px; z-index: 1001;">
  <i class="fas fa-comments fs-4"></i>
</button>

<script src="https://cdn.socket.io/4.7.5/socket.io.min.js"></script>
<script>
  const socket = io();
  const userNombre = "<%= user.nombre %>";
  const userRol = "<%= user.rol %>";
  let chatActual = null;

  function filterMatchesByDate(selectedDate) {
    const items = document.querySelectorAll('.match-item');
    let countVisible = 0;

    items.forEach(item => {
      if (item.getAttribute('data-date') === selectedDate) {
        item.classList.remove('partido-hidden');
        countVisible++;
      } else {
        item.classList.add('partido-hidden');
      }
    });

    const noMsg = document.getElementById('no-apuestas-msg');
    if (noMsg) {
      noMsg.style.display = countVisible === 0 ? 'block' : 'none';
      noMsg.innerText = "No hay partidos para el día " + selectedDate;
    }
  }

  function setQuickDate(daysToAdd) {
    const d = new Date();
    d.setDate(d.getDate() + daysToAdd);
    const iso = d.toISOString().split('T')[0];
    document.getElementById('main-date-picker').value = iso;
    filterMatchesByDate(iso);
  }

  window.onload = () => {
    const hoy = new Date().toISOString().split('T')[0];
    document.getElementById('main-date-picker').value = hoy;
    filterMatchesByDate(hoy);
  };

  document.querySelectorAll('.form-apuesta-ajax').forEach(form => {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = form.querySelector('button');
      const formData = new FormData(form);
      const data = {
        id_partido: formData.get('id_partido'),
        goles_a: formData.get('goles_a'),
        goles_b: formData.get('goles_b'),
        apostado: formData.get('apostado')
      };

      btn.disabled = true;
      btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i>';

      try {
        const res = await fetch('/apostar', {
          method: 'POST',
          headers: {'Content-Type': 'application/json'},
          body: JSON.stringify(data)
        });

        if (res.ok) {
          const card = form.closest('.card');
          const misApuestasContainer = document.getElementById('mis-apuestas-container');
          const noApuestasMsg = document.getElementById('no-apuestas-msg');
          if (noApuestasMsg) noApuestasMsg.style.display = 'none';

          const nuevaCard = card.cloneNode(true);
          nuevaCard.classList.add('border-success');
          nuevaCard.querySelector('form').remove();

          const divApuesta = document.createElement('div');
          divApuesta.className = 'text-center py-2 rounded-3 bg-white shadow-sm border border-success mt-2';
          divApuesta.innerHTML = `
            <span class="text-dark small fw-bold text-uppercase">Tu Apuesta: ${data.goles_a} - ${data.goles_b}</span>
            <div class="text-dark fw-bold small" style="font-size: 0.6rem;">(${data.apostado} GmC)</div>
          `;
          nuevaCard.appendChild(divApuesta);

          card.style.transition = 'all 0.4s ease';
          card.style.opacity = '0';
          card.style.transform = 'scale(0.8)';

          setTimeout(() => {
            card.remove();
            nuevaCard.style.opacity = '0';
            nuevaCard.style.transform = 'translateY(-20px)';
            misApuestasContainer.prepend(nuevaCard);

            setTimeout(() => {
              nuevaCard.style.transition = 'all 0.4s ease';
              nuevaCard.style.opacity = '1';
              nuevaCard.style.transform = 'translateY(0)';
            }, 50);
          }, 400);

          const creditosEl = document.getElementById('user-creditos-top');
          if(creditosEl) {
            const saldoActual = parseInt(creditosEl.innerText);
            creditosEl.innerText = saldoActual - parseInt(data.apostado);
          }

        } else {
          const errData = await res.json();
          alert(errData.error || "Error al apostar");
          btn.disabled = false;
          btn.innerHTML = '<i class="fas fa-check"></i>';
        }
      } catch (e) {
        console.error(e);
        btn.disabled = false;
        btn.innerHTML = '<i class="fas fa-check"></i>';
      }
    });
  });

  function renderSingleMessage(m) {
    const container = document.getElementById('chat-messages');
    if (!container) return;
    const isMe = m.usuario === userNombre;
    const div = document.createElement('div');
    div.className = `msg ${isMe ? 'msg-me' : 'msg-others'}`;
    div.id = `msg-${m.id}`;
    div.innerHTML = `<span class="msg-user">${m.usuario}</span><div>${m.mensaje}</div>`;
    container.appendChild(div);
    container.scrollTop = container.scrollHeight;
  }

  function setChat(id, titulo) {
    chatActual = id;
    document.getElementById('chat-title').innerText = titulo;
    document.getElementById('chat-container').style.display = 'flex';
    cargarMensajes();
  }

  async function cargarMensajes() {
    const container = document.getElementById('chat-messages');
    container.innerHTML = '';
    const res = await fetch(`/chat/${chatActual || ''}`);
    const mensajes = await res.json();
    mensajes.forEach(renderSingleMessage);
  }

  function toggleChat() {
    const chat = document.getElementById('chat-container');
    chat.style.display = (chat.style.display === 'none' || !chat.style.display) ? 'flex' : 'none';
  }

  async function enviarMensaje() {
    const input = document.getElementById('chat-input');
    const texto = input.value.trim();
    if(!texto) return;
    const res = await fetch('/chat/enviar', {
      method: 'POST',
      headers: {'Content-Type': 'application/json'},
      body: JSON.stringify({ mensaje: texto, id_partido: chatActual })
    });
    if(res.ok) input.value = '';
  }

  socket.on('nuevo_mensaje', (m) => {
    if (String(m.id_partido) === String(chatActual)) renderSingleMessage(m);
  });

  socket.on('actualizar_bolsa_live', (data) => {
    const el = document.querySelector(`.bolsa-partido-${data.id_partido}`);
    if(el) el.innerText = `${data.nuevo_total} GmC`;
  });
</script>
</body>
</html>