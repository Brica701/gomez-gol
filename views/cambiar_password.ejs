<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <!-- Meta tag crucial para que el responsive funcione en móviles -->
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Cambio Obligatorio - Gomez-Gol</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body {
            background: #0f172a;
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            margin: 0;
            padding: 15px; /* Espacio para que la card no toque los bordes en móvil */
        }

        .card {
            background: #1e293b;
            border: 1px solid #38bdf8;
            padding: 2rem;
            border-radius: 20px;
            width: 100%; /* Ocupa el ancho disponible */
            max-width: 400px; /* Pero no crece más de 400px en PC */
            box-shadow: 0 10px 30px rgba(0,0,0,0.5);
        }

        .form-control {
            background: #0f172a !important;
            border: 1px solid #475569 !important;
            color: white !important;
            padding: 0.75rem;
        }

        .form-control:focus {
            border-color: #38bdf8 !important;
            box-shadow: 0 0 0 0.25rem rgba(56, 189, 248, 0.25);
        }

        /* Ajuste de texto para pantallas muy pequeñas */
        @media (max-width: 350px) {
            .card { padding: 1.5rem; }
            h4 { font-size: 1.2rem; }
        }
    </style>
</head>
<body>

<div class="card shadow-lg text-center">
    <h4 class="text-info mb-4 fw-bold">Seguridad Gómez Moreno</h4>
    <p class="text-light opacity-75 mb-4">Por seguridad, debes cambiar la contraseña temporal asignada por el administrador.</p>

    <form action="/update-password" method="POST">
        <div class="mb-3">
            <input type="password" name="new_password" class="form-control text-center" placeholder="Nueva Contraseña" required minlength="4">
        </div>
        <button type="submit" class="btn btn-info w-100 fw-bold py-2">
            Actualizar y Entrar <i class="fas fa-sign-in-alt ms-1"></i>
        </button>
    </form>
</div>

</body>
</html>